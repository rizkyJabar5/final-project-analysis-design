<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!-- BPMN 2.0 process view: Transaction Payment — SAFE (STRIDE-mitigated).
     STRIDE controls applied per element:
       ✓S  Spoofing       → MFA + short-lived JWT; mTLS between internal services
       ✓T  Tampering      → TLS transport; HMAC-signed request body
       ✓R  Repudiation    → Append-only audit log; signed receipt returned to customer
       ✓I  Info Disclose  → AES-256 at rest; masked card data; generic error responses; least-privilege DB role
       ✓D  Denial of Svc  → Rate limiting; request timeouts; Idempotency-Key prevents double-charge
       ✓E  Elev Privilege → Server-side ownership check on source account; client-supplied account never trusted
--><bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" id="Defs_PaymentSafe" targetNamespace="http://example.org/stride">
  <bpmn:collaboration id="Collab_Payment">
    <bpmn:participant id="P_Payment" name="Transaction Payment (safe)" processRef="Proc_PaymentSafe">
      <bpmn:documentation id="documentation_tKbqnQ"/>
    </bpmn:participant>
    <bpmn:participant id="participant_OsVoWA" name="Default Process" processRef="process_XxIkag"/>
  </bpmn:collaboration>
  <bpmn:process id="Proc_PaymentSafe" isExecutable="false" processType="Private">
    <bpmn:laneSet id="Lanes_Payment">
      <!-- Trust boundary: Internet — external/untrusted -->
      <bpmn:lane id="L_Net" name="Internet (trust boundary)">
        <bpmn:documentation id="documentation_5BIxXQ"/>
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
      </bpmn:lane>
      <!-- Trust boundary: Internal Network — trusted services -->
      <bpmn:lane id="L_Int" name="Internal Network (trust boundary)">
        <bpmn:documentation id="documentation_UYrNuA"/>
        <bpmn:flowNodeRef>T_Gw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <!-- ── Elements ─────────────────────────────────────────────── -->
    <!-- External entity: Customer -->
    <bpmn:startEvent id="Start" name="POST /payment (TLS + MFA·JWT + Idempotency-Key)">
      <bpmn:documentation id="documentation_ft0k0A"/>
    </bpmn:startEvent>
    <!-- Process: API Gateway — closes S, T, D -->
    <bpmn:task id="T_Gw" name="API Gateway&#10;(authn · HMAC-verify · rate-limit · timeout)">
      <bpmn:documentation id="documentation_egx0cg"/>
    </bpmn:task>
    <!-- Process: Payment Service — closes E, R -->
    <bpmn:task id="T_Pay" name="Payment Service&#10;(server-side authz · ownership check · fraud-screen)">
      <bpmn:documentation id="documentation_z3bPMw"/>
    </bpmn:task>
    <!-- Data Store: Account / Ledger DB — closes I -->
    <bpmn:dataStoreReference id="DS_DB" name="Account / Ledger DB&#10;(AES-256 at rest · least-privilege role)">
      <bpmn:documentation id="documentation_02q0mA"/>
    </bpmn:dataStoreReference>
    <!-- Data Store: Audit Log — closes R -->
    <bpmn:dataStoreReference id="DS_Log" name="Audit Log&#10;(append-only · tamper-evident)">
      <bpmn:documentation id="documentation_jQ0vFg"/>
    </bpmn:dataStoreReference>
    <!-- End: signed receipt returned to customer — closes R -->
    <bpmn:endEvent id="End" name="Signed Receipt (signed response)">
      <bpmn:documentation id="documentation_kfPY1A"/>
    </bpmn:endEvent>
    <!-- ── Sequence Flows ─────────────────────────────────────────── -->
    <!-- Crosses trust boundary: Internet → Internal -->
    <bpmn:sequenceFlow id="f1" name="HTTPS/TLS · JWT Bearer · Idempotency-Key" sourceRef="Start" targetRef="T_Gw">
      <bpmn:documentation id="documentation_2kvHZw"/>
    </bpmn:sequenceFlow>
    <!-- Internal flow: API Gateway → Payment Service -->
    <bpmn:sequenceFlow id="f2" name="mTLS · validated token · HMAC body" sourceRef="T_Gw" targetRef="T_Pay">
      <bpmn:documentation id="documentation_Mc1lpQ"/>
    </bpmn:sequenceFlow>
    <!-- Internal flow: Payment Service → End -->
    <bpmn:sequenceFlow id="f3" name="signed receipt" sourceRef="T_Pay" targetRef="End">
      <bpmn:documentation id="documentation_VF8dZA"/>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <!-- ── Diagram Layout ─────────────────────────────────────────── -->
  <bpmn:process definitionalCollaborationRef="Collab_Payment" id="process_XxIkag" name="Default Process" processType="Public">
    <bpmn:documentation id="documentation_XWA8YQ"/>
    <bpmn:extensionElements>
      <open-bpmn:auto-align/>
    </bpmn:extensionElements>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dia_Payment">
    <bpmndi:BPMNPlane bpmnElement="Collab_Payment" id="Plane_Payment">
      <!-- Participant (outer pool) -->
      <bpmndi:BPMNShape bpmnElement="P_Payment" id="sh_P" isHorizontal="true">
        <dc:Bounds height="320" width="780" x="60" y="40"/>
      </bpmndi:BPMNShape>
      <!-- Lane: Internet -->
      <bpmndi:BPMNShape bpmnElement="L_Net" id="sh_LNet" isHorizontal="true">
        <dc:Bounds height="120" width="750" x="90" y="40"/>
      </bpmndi:BPMNShape>
      <!-- Lane: Internal Network -->
      <bpmndi:BPMNShape bpmnElement="L_Int" id="sh_LInt" isHorizontal="true">
        <dc:Bounds height="200" width="750" x="90" y="160"/>
      </bpmndi:BPMNShape>
      <!-- Start event -->
      <bpmndi:BPMNShape bpmnElement="Start" id="sh_Start">
        <dc:Bounds height="36" width="36" x="140" y="60"/>
        <bpmndi:BPMNLabel id="BPMNLabel_ZsJnUg">
          <dc:Bounds height="20.0" width="100.0" x="108.0" y="99.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- API Gateway task -->
      <bpmndi:BPMNShape bpmnElement="T_Gw" id="sh_Gw">
        <dc:Bounds height="80" width="180" x="240" y="180"/>
      </bpmndi:BPMNShape>
      <!-- Payment Service task -->
      <bpmndi:BPMNShape bpmnElement="T_Pay" id="sh_Pay">
        <dc:Bounds height="80" width="200" x="480" y="180"/>
      </bpmndi:BPMNShape>
      <!-- Account / Ledger DB -->
      <bpmndi:BPMNShape bpmnElement="DS_DB" id="sh_DB">
        <dc:Bounds height="60" width="100" x="490" y="300"/>
        <bpmndi:BPMNLabel id="BPMNLabel_SmFDXQ">
          <dc:Bounds height="20.0" width="100.0" x="465.0" y="350.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Audit Log -->
      <bpmndi:BPMNShape bpmnElement="DS_Log" id="sh_Log">
        <dc:Bounds height="60" width="100" x="620" y="300"/>
        <bpmndi:BPMNLabel id="BPMNLabel_Wr8oRQ">
          <dc:Bounds height="20.0" width="100.0" x="595.0" y="350.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- End event -->
      <bpmndi:BPMNShape bpmnElement="End" id="sh_End">
        <dc:Bounds height="36" width="36" x="760" y="202"/>
        <bpmndi:BPMNLabel id="BPMNLabel_XxBnGA">
          <dc:Bounds height="20.0" width="100.0" x="728.0" y="241.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Sequence flow edges -->
      <bpmndi:BPMNShape bpmnElement="participant_OsVoWA" id="BPMNShape_MhrREw">
        <dc:Bounds height="210.0" width="800.0" x="10.0" y="10.0"/>
        <bpmndi:BPMNLabel id="BPMNLabel_TEFqPw">
          <dc:Bounds height="20.0" width="100.0" x="10.0" y="10.0"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="f1" id="e_f1">
        <di:waypoint x="176.0" y="78.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <di:waypoint x="208.0" y="78.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <di:waypoint x="208.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <di:waypoint x="240.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <dc:Waypoint x="176" y="78"/>
        <dc:Waypoint x="330" y="78"/>
        <dc:Waypoint x="330" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f2" id="e_f2">
        <di:waypoint x="420.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <di:waypoint x="480.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <dc:Waypoint x="420" y="220"/>
        <dc:Waypoint x="480" y="220"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="f3" id="e_f3">
        <di:waypoint x="680.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <di:waypoint x="760.0" y="220.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI"/>
        <dc:Waypoint x="680" y="220"/>
        <dc:Waypoint x="760" y="220"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
