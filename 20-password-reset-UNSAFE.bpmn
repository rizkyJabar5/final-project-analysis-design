<?xml version="1.0" encoding="UTF-8"?>
<!-- BPMN 2.0 process view: Password Reset — UNSAFE. No trust boundary separation. -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  id="Defs_PwResetUnsafe" targetNamespace="http://example.org/stride">
  <bpmn:process id="Proc_PwResetUnsafe" isExecutable="false">
    <bpmn:startEvent id="Start" name="POST /forgot {email} (HTTP)"/>
    <bpmn:task id="T_Gw"    name="API Gateway (no rate limit)"/>
    <bpmn:task id="T_Reset" name="Reset Service (unbound, non-expiring token)"/>
    <bpmn:dataStoreReference id="DS_Tdb" name="Reset Token Store (seq, plaintext)"/>
    <bpmn:task id="T_Mail"  name="Email link ?token=NNN (HTTP)"/>
    <bpmn:task id="T_Redeem" name="GET /reset?token=NNN {newPassword}"/>
    <bpmn:dataStoreReference id="DS_Udb" name="User Credential Store"/>
    <bpmn:endEvent id="End" name="Password changed (no notice/log)"/>
    <bpmn:sequenceFlow id="f1" name="HTTP" sourceRef="Start" targetRef="T_Gw"/>
    <bpmn:sequenceFlow id="f2" name="create token" sourceRef="T_Gw" targetRef="T_Reset"/>
    <bpmn:sequenceFlow id="f3" name="email token in URL" sourceRef="T_Reset" targetRef="T_Mail"/>
    <bpmn:sequenceFlow id="f4" name="user clicks link" sourceRef="T_Mail" targetRef="T_Redeem"/>
    <bpmn:sequenceFlow id="f5" name="update password" sourceRef="T_Redeem" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dia">
    <bpmndi:BPMNPlane id="Plane" bpmnElement="Proc_PwResetUnsafe">
      <bpmndi:BPMNShape id="s0" bpmnElement="Start"><dc:Bounds x="100" y="100" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s1" bpmnElement="T_Gw"><dc:Bounds x="180" y="80" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s2" bpmnElement="T_Reset"><dc:Bounds x="340" y="80" width="150" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s3" bpmnElement="DS_Tdb"><dc:Bounds x="360" y="220" width="110" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s4" bpmnElement="T_Mail"><dc:Bounds x="530" y="80" width="140" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s5" bpmnElement="T_Redeem"><dc:Bounds x="710" y="80" width="160" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s6" bpmnElement="DS_Udb"><dc:Bounds x="740" y="220" width="120" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s7" bpmnElement="End"><dc:Bounds x="910" y="100" width="36" height="36"/></bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
