<?xml version="1.0" encoding="UTF-8"?>
<!-- BPMN 2.0 process view: User Transaction — SAFE. Internal services in a trust-boundary lane. -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  id="Defs_TxnSafe" targetNamespace="http://example.org/stride">
  <bpmn:collaboration id="Collab"><bpmn:participant id="P" name="User Transaction (safe)" processRef="Proc_TxnSafe"/></bpmn:collaboration>
  <bpmn:process id="Proc_TxnSafe" isExecutable="false">
    <bpmn:laneSet id="Lanes">
      <bpmn:lane id="L_Net" name="Internet (trust boundary)"><bpmn:flowNodeRef>Start</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Int" name="Internal Network (trust boundary)">
        <bpmn:flowNodeRef>T_Gw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Txn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Submit Transfer (TLS, MFA+JWT)"/>
    <bpmn:task id="T_Gw"  name="API Gateway (authn, HMAC, rate limit)"/>
    <bpmn:task id="T_Txn" name="Transaction Service (server-side authz)"/>
    <bpmn:dataStoreReference id="DS_DB"  name="Account / Ledger DB (encrypted)"/>
    <bpmn:dataStoreReference id="DS_Log" name="Audit Log (append-only)"/>
    <bpmn:endEvent id="End" name="Signed receipt"/>
    <bpmn:sequenceFlow id="f1" name="TLS, Idempotency-Key" sourceRef="Start" targetRef="T_Gw"/>
    <bpmn:sequenceFlow id="f2" name="mTLS, validated token" sourceRef="T_Gw"  targetRef="T_Txn"/>
    <bpmn:sequenceFlow id="f3" name="signed receipt"        sourceRef="T_Txn" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dia">
    <bpmndi:BPMNPlane id="Plane" bpmnElement="Collab">
      <bpmndi:BPMNShape id="s0" bpmnElement="Start"><dc:Bounds x="120" y="100" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s1" bpmnElement="T_Gw"><dc:Bounds x="210" y="80" width="130" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s2" bpmnElement="T_Txn"><dc:Bounds x="390" y="80" width="140" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s3" bpmnElement="DS_DB"><dc:Bounds x="410" y="220" width="80" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s5" bpmnElement="DS_Log"><dc:Bounds x="520" y="220" width="80" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s4" bpmnElement="End"><dc:Bounds x="590" y="100" width="36" height="36"/></bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
