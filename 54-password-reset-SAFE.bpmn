<?xml version="1.0" encoding="UTF-8"?>
<!-- BPMN 2.0 process view: Password Reset — SAFE. Internal services in a trust-boundary lane. -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Defs_PwResetSafe" targetNamespace="http://example.org/stride">
  <bpmn:collaboration id="Collab"><bpmn:participant id="P" name="Password Reset (safe)" processRef="Proc_PwResetSafe"/></bpmn:collaboration>
  <bpmn:process id="Proc_PwResetSafe" isExecutable="false">
    <bpmn:laneSet id="Lanes">
      <bpmn:lane id="L_Net" name="Internet (trust boundary)">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Mail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Redeem</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Int" name="Internal Network (trust boundary)">
        <bpmn:flowNodeRef>T_Gw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Reset</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="POST /forgot (TLS + CAPTCHA)"/>
    <bpmn:task id="T_Gw"    name="API Gateway (rate limited, audit-logged to DS_Log)"/>
    <bpmn:task id="T_Reset" name="Reset Service (bound, single-use, 15m TTL, audit-logged to DS_Log)"/>
    <bpmn:dataStoreReference id="DS_Tdb" name="Reset Token Store (SHA-256 hash, encrypted at rest, least-privilege access)"/>
    <bpmn:task id="T_Mail"  name="Email link ?token=&lt;128-bit&gt; (HTTPS + S/MIME or PGP end-to-end encryption)"/>
    <bpmn:task id="T_Redeem" name="POST /reset {token,newPassword} (TLS, audit-logged to DS_Log)"/>
    <bpmn:dataStoreReference id="DS_Udb" name="User Credential Store (argon2, encrypted at rest, strict access controls)"/>
    <bpmn:dataStoreReference id="DS_Log" name="Audit Log (append-only, cryptographically signed)"/>
    <bpmn:endEvent id="End" name="Reset + sessions invalidated + notice"/>
    <bpmn:sequenceFlow id="f1" name="TLS" sourceRef="Start" targetRef="T_Gw"/>
    <bpmn:sequenceFlow id="f2" name="create token (TLS/mTLS)" sourceRef="T_Gw" targetRef="T_Reset"/>
    <bpmn:sequenceFlow id="f3" name="email token (HTTPS)" sourceRef="T_Reset" targetRef="T_Mail"/>
    <bpmn:sequenceFlow id="f4" name="user clicks link" sourceRef="T_Mail" targetRef="T_Redeem"/>
    <bpmn:sequenceFlow id="f5" name="validate + update (TLS)" sourceRef="T_Redeem" targetRef="End"/>
    <bpmn:dataAssociation id="da1" sourceRef="T_Gw"    targetRef="DS_Log"><bpmn:assignment><bpmn:from xsi:type="bpmn:tFormalExpression">gateway audit event</bpmn:from><bpmn:to xsi:type="bpmn:tFormalExpression">append</bpmn:to></bpmn:assignment></bpmn:dataAssociation>
    <bpmn:dataAssociation id="da2" sourceRef="T_Reset"  targetRef="DS_Log"><bpmn:assignment><bpmn:from xsi:type="bpmn:tFormalExpression">token create / validate / redeem event</bpmn:from><bpmn:to xsi:type="bpmn:tFormalExpression">append</bpmn:to></bpmn:assignment></bpmn:dataAssociation>
    <bpmn:dataAssociation id="da3" sourceRef="T_Reset"  targetRef="DS_Tdb"><bpmn:assignment><bpmn:from xsi:type="bpmn:tFormalExpression">hashed token (SHA-256)</bpmn:from><bpmn:to xsi:type="bpmn:tFormalExpression">write</bpmn:to></bpmn:assignment></bpmn:dataAssociation>
    <bpmn:dataAssociation id="da4" sourceRef="T_Reset"  targetRef="DS_Udb"><bpmn:assignment><bpmn:from xsi:type="bpmn:tFormalExpression">updated credential (argon2)</bpmn:from><bpmn:to xsi:type="bpmn:tFormalExpression">write</bpmn:to></bpmn:assignment></bpmn:dataAssociation>
    <bpmn:dataAssociation id="da5" sourceRef="T_Redeem" targetRef="DS_Log"><bpmn:assignment><bpmn:from xsi:type="bpmn:tFormalExpression">redemption attempt / success with timestamp + user id</bpmn:from><bpmn:to xsi:type="bpmn:tFormalExpression">append</bpmn:to></bpmn:assignment></bpmn:dataAssociation>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dia">
    <bpmndi:BPMNPlane id="Plane" bpmnElement="Collab">
      <bpmndi:BPMNShape id="s0" bpmnElement="Start"><dc:Bounds x="100" y="100" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s1" bpmnElement="T_Gw"><dc:Bounds x="180" y="80" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s2" bpmnElement="T_Reset"><dc:Bounds x="340" y="80" width="170" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s3" bpmnElement="DS_Tdb"><dc:Bounds x="360" y="240" width="130" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s4" bpmnElement="T_Mail"><dc:Bounds x="550" y="80" width="160" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s5" bpmnElement="T_Redeem"><dc:Bounds x="750" y="80" width="170" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s6" bpmnElement="DS_Udb"><dc:Bounds x="780" y="240" width="130" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s8" bpmnElement="DS_Log"><dc:Bounds x="940" y="240" width="120" height="60"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s7" bpmnElement="End"><dc:Bounds x="960" y="100" width="36" height="36"/></bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
