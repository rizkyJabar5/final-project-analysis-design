<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!-- BPMN 2.0 process view: Password Reset — SAFE. Internal services in a trust-boundary lane. --><bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" id="Defs_PwResetSafe" targetNamespace="http://example.org/stride">
  <bpmn:collaboration id="Collab">
    <bpmn:participant id="P" name="Password Reset (safe)" processRef="Proc_PwResetSafe">
      <bpmn:documentation id="documentation_eX0iHg"/>
    </bpmn:participant>
    <bpmn:participant id="participant_xKsFtQ" name="Default Process" processRef="process_yi1JAw"/>
  </bpmn:collaboration>
  <bpmn:process id="Proc_PwResetSafe" isExecutable="false" processType="Private">
    <bpmn:laneSet id="Lanes">
      <bpmn:lane id="L_Net" name="Internet (trust boundary)">
        <bpmn:documentation id="documentation_8AiwXw"/>
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Mail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Redeem</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Int" name="Internal Network (trust boundary)">
        <bpmn:documentation id="documentation_0VXSTg"/>
        <bpmn:flowNodeRef>T_Gw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Reset</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="POST /forgot (TLS + CAPTCHA)">
      <bpmn:documentation id="documentation_o8uSsQ"/>
    </bpmn:startEvent>
    <bpmn:task id="T_Gw" name="API Gateway (rate limited)">
      <bpmn:documentation id="documentation_oRhKIQ"/>
    </bpmn:task>
    <bpmn:task id="T_Reset" name="Reset Service (bound, single-use, 15m TTL)">
      <bpmn:documentation id="documentation_GJguZA"/>
    </bpmn:task>
    <bpmn:dataStoreReference id="DS_Tdb" name="Reset Token Store (SHA-256 hash)">
      <bpmn:documentation id="documentation_6C3thw"/>
    </bpmn:dataStoreReference>
    <bpmn:task id="T_Mail" name="Email link ?token=&lt;128-bit&gt; (HTTPS)">
      <bpmn:documentation id="documentation_0NJC4w"/>
    </bpmn:task>
    <bpmn:task id="T_Redeem" name="POST /reset {token,newPassword} (TLS)">
      <bpmn:documentation id="documentation_97qi2Q"/>
    </bpmn:task>
    <bpmn:dataStoreReference id="DS_Udb" name="User Credential Store (argon2)">
      <bpmn:documentation id="documentation_H5U0fA"/>
    </bpmn:dataStoreReference>
    <bpmn:dataStoreReference id="DS_Log" name="Audit Log (append-only)">
      <bpmn:documentation id="documentation_59Fktw"/>
    </bpmn:dataStoreReference>
    <bpmn:endEvent id="End" name="Reset + sessions invalidated + notice">
      <bpmn:documentation id="documentation_nZ28gw"/>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" name="TLS" sourceRef="Start" targetRef="T_Gw">
      <bpmn:documentation id="documentation_Ew1Cpg"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f2" name="create token" sourceRef="T_Gw" targetRef="T_Reset">
      <bpmn:documentation id="documentation_3PIRcw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f3" name="email token (HTTPS)" sourceRef="T_Reset" targetRef="T_Mail">
      <bpmn:documentation id="documentation_zOYe8A"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f4" name="user clicks link" sourceRef="T_Mail" targetRef="T_Redeem">
      <bpmn:documentation id="documentation_zrJamQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f5" name="validate + update" sourceRef="T_Redeem" targetRef="End">
      <bpmn:documentation id="documentation_KQpMtA"/>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmn:process definitionalCollaborationRef="Collab" id="process_yi1JAw" name="Default Process" processType="Public">
    <bpmn:documentation id="documentation_w1AMfg"/>
    <bpmn:extensionElements>
      <open-bpmn:auto-align/>
    </bpmn:extensionElements>
  </bpmn:process>
