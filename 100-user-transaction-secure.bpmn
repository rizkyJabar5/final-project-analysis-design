<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Claude" exporterVersion="2.0" id="Definitions_SecureUserTransaction" targetNamespace="http://stride.example/secure-user-transaction">
  <bpmn:process id="Process_SecureUserTransaction" isExecutable="true" name="Secure User Transaction (STRIDE Mitigated)" processType="Public">
    <bpmn:documentation>
      Secure User Transaction Process - STRIDE Valid Design
      All six STRIDE categories are mitigated:

      S - Spoofing:
        - MFA + biometric + device attestation
        - [Task_AuditLog] HSM key storage, key rotation, unauthorized use monitoring
        - [Task_IssueJWT] HSM key storage, regular key rotation, short token lifetimes
        - [Task_Authenticate] Hardware-backed device attestation, anti-phishing measures
        - [Flow_4] Strict cert validation with CRL/OCSP, HSM private keys, cert rotation

      T - Tampering:
        - TLS 1.3 + JWT signature + request signing
        - [DataStore_Logs] Authenticated encryption (AES-GCM) for integrity protection + Write-once storage
        - [Task_AuditLog] HSM key storage, key rotation, unauthorized use monitoring + Access controls + Encryption at rest/transit + Pre-redaction
        - [Task_IssueJWT] HSM key storage, regular key rotation, short token lifetimes
        - [Task_Authz] OPA policies deployed read-only in production with controlled deployment pipeline + File integrity monitoring
        - [Flow_4] mTLS between Authenticate and Gateway_Auth
        - [Flow_5] mTLS between Gateway_Auth and IssueJWT
        - [Flow_7] mTLS between ValidateJWT and Gateway_JWT
        - [Flow_8] mTLS between Gateway_JWT and Authz
        - [Flow_9] mTLS between Authz and ValidateInput
        - [Flow_10] mTLS between ValidateInput and TransactDB

      R - Repudiation: Immutable audit log + signed entries
        - [Task_UserLogin] Logs all login attempts (username, timestamp, outcome) to immutable audit log
        - [Task_Authz] Logs all authorization decisions (allow/deny) with user identity, resource, and action
        - [Task_IssueJWT] Logs JWT issuance events (subject, scopes, expiry) to immutable audit log
        - [Task_Authenticate] Logs authentication decisions (success/failure) with user ID, timestamp, reason
        - [Task_ValidateJWT] Logs JWT validation failures with reason and context (token ID, timestamp)

      I - Information Disclosure:
        - TDE + PII redaction + encrypted backups
        - [DataStore_AuditLog] TDE or file-level encryption with KMS-managed key
        - [Task_AuditLog] Access controls on audit log storage, encryption at rest and in transit, pre-redaction of sensitive data
        - [Task_RedactedLog] Robust PII detection and redaction with regular testing
        - [Task_Authenticate] Generic error messages that do not reveal specific failure reasons
        - [Task_Authz] Minimized sensitive information in authorization decision logs
        - [Task_IssueJWT] Redaction of sensitive claims (e.g., personal data) before logging
        - [Task_UserLogin] Generic error messages to prevent username enumeration
        - [Task_ValidateJWT] Generic error messages for validation failures, detailed reasons logged internally
        - [Flow_3] Internal TLS/mTLS for credential transmission
        - [Flow_6] Internal TLS or JWE for JWT payload encryption
        - [Flow_11] TLS/JWE for transaction data before audit logging
        - [Flow_12] TLS/AES-GCM for unredacted logs to redaction service
        - [Flow_NoAuth] Generic error messages, redacted internal logs
        - [Flow_InvalidJWT] Generic error responses, detailed errors logged internally

      D - Denial of Service:
        - Rate limiting + WAF + DDoS mitigation
        - [Task_TransactDB] Rate limiting, throttling, query timeouts, and resource limits (max execution time, memory limits)
        - [Task_TLS] Connection limits, rate limiting at network edge, DDoS services
        - [DataStore_Logs] Write-once storage with regular backups and integrity checks to prevent log deletion
        - [Task_ValidateInput] Input size limits, rate limiting, resource quotas, and timeouts

      E - Elevation of Privilege:
        - RBAC + OPA + least privilege DB user
        - [Task_Authz] Policy-as-code with version control, regular reviews, automated testing
        - [Task_IssueJWT] Strict scope assignment based on authenticated user roles with regular auditing and testing
    </bpmn:documentation>
    <bpmn:extensionElements>
      <open-bpmn:auto-align/>
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_1" name="Begin Transaction">
      <bpmn:documentation id="documentation_start"/>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_TLS" name="TLS 1.3 + HSTS + Cert Pinning + Connection Limits + DDoS Mitigation">
      <bpmn:documentation id="documentation_tls"/>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_UserLogin" name="User Login (Username + Password + MFA + Biometric + Login Attempt Logging + Generic Error Messages)">
      <bpmn:documentation id="documentation_login">Logs all login attempts (username, timestamp, outcome) to immutable audit log for repudiation prevention. Uses generic error messages (e.g., 'Invalid username or password') to prevent username enumeration.</bpmn:documentation>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_Authenticate" name="Authenticate (bcrypt + HW-Backed Device Attestation + Rate Limit + Anti-Phishing + Auth Decision Logging + Generic Errors)">
      <bpmn:documentation id="documentation_authenticate">Logs authentication decisions (success/failure) with user ID, timestamp, and reason internally. Returns generic error messages that do not reveal specific failure reasons (e.g., invalid password vs. invalid device).</bpmn:documentation>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Auth" name="Authenticated?">
      <bpmn:documentation id="documentation_auth_check"/>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_NoAuth</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Reject" name="Generic Error (No Details) + Redacted Audit Log">
      <bpmn:documentation id="documentation_reject"/>
      <bpmn:incoming>Flow_NoAuth</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_IssueJWT" name="Issue JWT (RS256 Signed, HSM Key, Short Expiry, Scope Bound, Key Rotation + JWT Issuance Logging + Sensitive Claim Redaction + Strict Scope Assignment)">
      <bpmn:documentation id="documentation_issue_jwt">Logs JWT issuance events (subject, scopes, expiry, timestamp) to the immutable audit log. Redacts sensitive claims (e.g., personal data) before logging. Implements strict scope assignment based on authenticated user roles and permissions with regular auditing and testing.</bpmn:documentation>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ValidateJWT" name="Validate JWT (Verify Signature + Issuer + Audience + Expiry + Scope + Validation Failure Logging + Generic Errors)">
      <bpmn:documentation id="documentation_validate_jwt">Logs JWT validation failures with reason and context (token ID, timestamp) for repudiation prevention. Returns generic error messages for validation failures without revealing specific reasons (e.g., expired, wrong issuer). Detailed reasons logged internally only.</bpmn:documentation>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_JWT" name="JWT Valid?">
      <bpmn:documentation id="documentation_jwt_check"/>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_InvalidJWT</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_InvalidJWT" name="Generic 401 Error (No Details) + Internal Audit Log">
      <bpmn:documentation id="documentation_invalid_jwt"/>
      <bpmn:incoming>Flow_InvalidJWT</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_Authz" name="RBAC + OPA Policy-as-Code + Scope Check + Version Control + Automated Testing + Auth Decision Logging + Read-Only Policies + Minimized Log Info">
      <bpmn:documentation id="documentation_authz">Logs authorization decisions (allow/deny) with user identity, resource, and action to the immutable audit log. OPA policies deployed read-only in production with changes only through controlled deployment pipeline. File integrity monitoring on policy files. Minimizes sensitive information in authorization decision logs.</bpmn:documentation>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ValidateInput" name="Input Validation + Allowlist + Parameterized Query + Input Size Limits + Rate Limiting + Resource Quotas">
      <bpmn:documentation id="documentation_validate_input">Implements input size limits and rate limiting at the input validation stage. Uses resource quotas and timeouts to prevent resource exhaustion from large payloads.</bpmn:documentation>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TransactDB" name="Execute Transaction (Parameterized Query + TDE + KMS + Constraints + Rate Limit + Query Timeout + Resource Limits)">
      <bpmn:documentation id="documentation_transact_db">Configures database query timeouts and resource limits (max execution time, memory limits) to prevent slow query attacks and resource exhaustion.</bpmn:documentation>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DOA_TxDB">
        <bpmn:targetRef>DataStore_TxDB</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_AuditLog" name="Sign &amp; Append Audit Log (WORM, Immutable, HSM Key, Key Rotation + Access Controls + Encryption at Rest/Transit + Pre-Redaction)">
      <bpmn:documentation id="documentation_audit_log">Implements access controls on audit log storage, encryption at rest and in transit, and redacts sensitive information before writing to the audit log.</bpmn:documentation>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DOA_Audit">
        <bpmn:targetRef>DataStore_AuditLog</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:script id="script_audit"/>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Task_RedactedLog" name="Centralized Logging with PII Redaction (AES-GCM Authenticated Encryption + Robust PII Detection + Regular Testing)">
      <bpmn:documentation id="documentation_redacted_log">Implements robust PII detection and redaction mechanisms. Regularly tests the redaction process with sample data to ensure effectiveness and prevent sensitive information leakage.</bpmn:documentation>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DOA_Logs">
        <bpmn:targetRef>DataStore_Logs</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Success" name="Transaction Success + Masked Receipt (Session-Bound)">
      <bpmn:documentation id="documentation_success"/>
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataStoreReference id="DataStore_TxDB" name="Transactions DB (TDE + KMS + RBAC + Audit Triggers)">
      <bpmn:documentation id="documentation_db"/>
    </bpmn:dataStoreReference>
    <bpmn:dataStoreReference id="DataStore_AuditLog" name="Immutable Audit Log (WORM + HSM Signed + TDE/KMS Encrypted)">
      <bpmn:documentation id="documentation_audit"/>
    </bpmn:dataStoreReference>
    <bpmn:dataStoreReference id="DataStore_Logs" name="Centralized Logs (Redacted + AES-GCM Authenticated Encryption + Write-Once Storage + Regular Backups + Integrity Checks)">
      <bpmn:documentation id="documentation_logs">Write-once storage with regular backups and integrity checks to prevent log deletion by attackers.</bpmn:documentation>
    </bpmn:dataStoreReference>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_TLS">
      <bpmn:documentation id="documentation_f1"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_TLS" targetRef="Task_UserLogin">
      <bpmn:documentation id="documentation_f2"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_3" name="Internal mTLS" sourceRef="Task_UserLogin" targetRef="Task_Authenticate">
      <bpmn:documentation id="documentation_f3"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4" name="mTLS + CRL/OCSP" sourceRef="Task_Authenticate" targetRef="Gateway_Auth">
      <bpmn:documentation id="documentation_f4"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoAuth" name="No" sourceRef="Gateway_Auth" targetRef="EndEvent_Reject">
      <bpmn:documentation id="documentation_f_noauth"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" name="Yes + mTLS" sourceRef="Gateway_Auth" targetRef="Task_IssueJWT">
      <bpmn:documentation id="documentation_f5"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" name="Internal TLS/JWE" sourceRef="Task_IssueJWT" targetRef="Task_ValidateJWT">
      <bpmn:documentation id="documentation_f6"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_7" name="mTLS" sourceRef="Task_ValidateJWT" targetRef="Gateway_JWT">
      <bpmn:documentation id="documentation_f7"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_InvalidJWT" name="No" sourceRef="Gateway_JWT" targetRef="EndEvent_InvalidJWT">
      <bpmn:documentation id="documentation_f_invalidjwt"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_8" name="Yes + mTLS" sourceRef="Gateway_JWT" targetRef="Task_Authz">
      <bpmn:documentation id="documentation_f8"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_9" name="mTLS" sourceRef="Task_Authz" targetRef="Task_ValidateInput">
      <bpmn:documentation id="documentation_f9"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" name="mTLS" sourceRef="Task_ValidateInput" targetRef="Task_TransactDB">
      <bpmn:documentation id="documentation_f10"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_11" name="TLS/JWE" sourceRef="Task_TransactDB" targetRef="Task_AuditLog">
      <bpmn:documentation id="documentation_f11"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_12" name="TLS/AES-GCM" sourceRef="Task_AuditLog" targetRef="Task_RedactedLog">
      <bpmn:documentation id="documentation_f12"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_RedactedLog" targetRef="EndEvent_Success">
      <bpmn:documentation id="documentation_f13"/>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
